  "name": "Active EU customers — last 30d",
  "description": "Customers in EU countries with a recent order.",
  "base": { "kind": "table", "schema": "public", "table": "customers" },
  "columns": [
    { "source": { "column": "id" }, "readonly": true, "width": 80 },
