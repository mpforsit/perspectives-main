{
  "name": "@perspectives/desktop",
  "version": "0.0.1",
  "private": true,
  "description": "Perspectives — the Electron desktop application.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "pnpm rebuild:electron && env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder",
    "package:dir": "electron-vite build && electron-builder --dir",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "lint": "eslint src test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3 -p",
    "rebuild:node": "pnpm rebuild better-sqlite3"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@perspectives/adapter-postgres": "workspace:*",
    "@perspectives/dsl": "workspace:*",
    "@perspectives/engine": "workspace:*",
    "@perspectives/metadata-sqlite": "workspace:*",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.26",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@uiw/react-codemirror": "^4.25.10",
    "better-sqlite3": "^12.10.0",
    "pg": "^8.13.1",
    "superjson": "^2.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.2",
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.4",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@testcontainers/postgresql": "^12.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.2",
    "electron-builder-squirrel-windows": "^26.15.2",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.453.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "testcontainers": "^12.0.1",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
